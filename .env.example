# Copy to .env.local for local dev, and set the same values in Netlify → Site
# settings → Environment variables for production.

# --- Supabase (client-safe; the anon key is meant to ship to the browser) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Google Gemini (SERVER ONLY — never prefixed with VITE_, never in the bundle) ---
# Used by netlify/functions/ai.mjs. Free key from https://aistudio.google.com.
# Set in Netlify env; for local function dev run `netlify dev` with this set.
GEMINI_API_KEY=...

# Leave the Supabase vars unset to run the app in local-only mode
# (IndexedDB, no shared board, no auth server) for offline development.
